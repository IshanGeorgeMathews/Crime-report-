# ============================================================
# Kerala Police Intelligence Platform — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values.
# Never commit the .env file to source control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up --build

# --- Neo4j Graph Database ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ChangeMe_Neo4j
NEO4J_DATABASE=prosecutorreport

# --- SQLite (default) or PostgreSQL ---
# For Docker: use the sqlite default below (file stored in container volume)
# For PostgreSQL: DATABASE_URL=postgresql+asyncpg://user:pass@postgres:5432/kpip
DATABASE_URL=sqlite+aiosqlite:///./kpip.db

# --- Qdrant Vector Database ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# --- Ollama LLM Server ---
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen:8b

# --- JWT Secret Key (change to a long random string in production) ---
SECRET_KEY=replace-with-a-long-random-secret-key-in-production

# --- NER & Translation Models ---
NER_MODEL_PATH=dslim/bert-base-NER
TRANSLATION_MODEL_PATH=ai4bharat/indictrans2-indic-en-1B
SENTENCE_TRANSFORMER_MODEL_PATH=all-MiniLM-L6-v2
# Set to 1 to disable the heavy IndicTrans2 local model (uses Google Translate fallback)
DISABLE_INDIC_TRANS=1

# --- Report Template Directory ---
# Path to the PP Form template folder inside the container (or on the host for local dev)
# In Docker this is mounted via the volumes section in docker-compose.yml
PP_DIR=/app/pp_templates

# --- CORS (comma-separated allowed origins) ---
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# Backend-specific environment variables
# These are consumed by FastAPI / pydantic-settings when running the backend directly
# (without Docker). For Docker deployments, use the root .env.example instead.
#
# Usage (local dev without Docker):
#   cp backend/.env.example backend/.env
#   # Edit backend/.env with your local values

DATABASE_URL=sqlite+aiosqlite:///./kpip.db

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ChangeMe_Neo4j
NEO4J_DATABASE=prosecutorreport

QDRANT_HOST=localhost
QDRANT_PORT=6333

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen:8b

SECRET_KEY=replace-with-a-long-random-secret-key-in-production

NER_MODEL_PATH=dslim/bert-base-NER
TRANSLATION_MODEL_PATH=ai4bharat/indictrans2-indic-en-1B
SENTENCE_TRANSFORMER_MODEL_PATH=all-MiniLM-L6-v2
DISABLE_INDIC_TRANS=1

# Path to PP Form templates directory on your local machine
# PP_DIR=/path/to/your/local/PP & Uo Note Dummy folder

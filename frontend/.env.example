# Frontend environment variables (consumed by Vite at build time)
# Copy this to frontend/.env and adjust as needed.
#
# For Docker: the frontend container proxies /api → backend API service,
# so set VITE_API_URL to a relative path or leave it to use the default.
#
# For local dev: point to your running FastAPI server.

# Backend API base URL (no trailing slash)
# Local dev:   http://localhost:8000/api/v1
# Docker/prod: /api/v1  (Nginx proxies /api to the backend container)
VITE_API_URL=http://localhost:8000/api/v1

# Set to "false" to hit the real backend. Set to "true" for UI-only development with mocks.
VITE_USE_MOCK=false
